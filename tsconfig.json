{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "verbatimModuleSyntax": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": { "~/*": ["src/*"], "astro": ["./node_modules/astro"] },
    "plugins": [{ "name": "@astrojs/ts-plugin" }],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
